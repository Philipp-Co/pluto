#
# ---------------------------------------------------------------------------------------------------------------------
#
# https://docs.docker.com/build/building/multi-stage/

from ubuntu:20.04

RUN apt-get update
RUN apt-get install python3 -y

COPY --from=pluto:latest /build/pluto_node/pluto_node_pt /bin/pluto_node_pt 
COPY --from=pluto:latest /build/pluto_info/pluto_info /bin/pluto_info 
COPY --from=pluto:latest /build/pluto_rw/pluto_rw /bin/pluto_rw

RUN echo {\"work_dir\":\"/pluto/ipc/\",\"name_of_input_queue\":\"pluto-0_iq\",\"names_of_output_queues\":[\"pluto-0_oq_0\"]} > /pluto-0-config.txt
RUN echo {\"work_dir\":\"/pluto/ipc/\",\"name_of_input_queue\":\"pluto-0_oq_0\",\"names_of_output_queues\":[\"pluto-1_oq_0\"]} > /pluto-1-config.txt
COPY docker/demo/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV PLUTO_PYTHON_PATH=/usr/lib/python38.zip;/usr/lib/python3.8;/usr/lib/python3.8/lib-dynload;/usr/local/lib/python3.8/dist-packages;/usr/lib/python3/dist-packages

CMD ["/entrypoint.sh"]

#
# ---------------------------------------------------------------------------------------------------------------------
